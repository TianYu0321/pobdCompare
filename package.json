{
  "name": "poe2-bd-analyzer",
  "version": "0.1.0",
  "description": "PoE2 BD 差异比较与收益模拟工具 — 基于 PoB2 反事实重算",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm run dev --workspace @pobd/api\" \"npm run dev --workspace @pobd/web\"",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "mapping:failures": "tsx packages/adapters/src/cache/failure-cli.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
